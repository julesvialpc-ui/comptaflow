generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum BusinessType {
  AUTO_ENTREPRENEUR
  EI
  EIRL
  EURL
  SARL
  SAS
  SASU
  SA
  OTHER
}

enum ActivityType {
  BIC_VENTE      // Vente de marchandises — 12,3 %
  BIC_SERVICES   // Prestations de services — 21,2 %
  BNC            // Activités libérales hors CIPAV — 25,6 %
  BNC_CIPAV      // Activités libérales CIPAV — 23,2 %
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum ExpenseCategory {
  OFFICE_SUPPLIES
  TRAVEL
  MEALS
  EQUIPMENT
  SOFTWARE
  MARKETING
  PROFESSIONAL_FEES
  RENT
  UTILITIES
  INSURANCE
  TAXES
  SALARY
  OTHER
}

enum RevenueCategory {
  SERVICES
  PRODUCTS
  CONSULTING
  FREELANCE
  SUBSCRIPTION
  RENTAL
  OTHER
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
}

enum TaxReportStatus {
  DRAFT
  SUBMITTED
  VALIDATED
}

enum TaxReportType {
  TVA
  IS
  IR
  URSSAF
  CFE
  OTHER
}

enum NotificationType {
  INVOICE_DUE
  INVOICE_PAID
  TAX_DEADLINE
  EXPENSE_REMINDER
  SYSTEM
  AI_INSIGHT
  INVOICE_OVERDUE
  URSSAF_DEADLINE
  BUDGET_EXCEEDED
  THRESHOLD_WARNING
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
  INACTIVE
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  ALTERNANCE
  STAGE
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String?
  avatarUrl    String?
  role         UserRole  @default(USER)
  isVerified   Boolean   @default(false)
  refreshToken String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business      Business?
  notifications Notification[]
  chatMessages  ChatMessage[]
  subscription  Subscription?

  @@map("users")
}

model Business {
  id          String       @id @default(uuid())
  userId      String       @unique
  name        String
  siret       String?      @unique
  siren       String?      @unique
  vatNumber   String?
  type        BusinessType @default(AUTO_ENTREPRENEUR)
  activityType ActivityType @default(BIC_SERVICES)
  address     String?
  city        String?
  postalCode  String?
  country     String       @default("FR")
  phone       String?
  website     String?
  logoUrl     String?
  iban        String?
  bic         String?
  revenueGoal    Float?
  isVatSubject   Boolean @default(false)
  defaultVatRate Float   @default(0.20)
  hasEmployees   Boolean @default(false)
  // Artisan-specific fields
  rgeNumber             String?   // Certification RGE
  decennialInsuranceRef String?   // N° assurance décennale
  kbisNumber            String?   // Extrait Kbis
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients          Client[]
  invoices         Invoice[]
  transactions     Transaction[]
  expenses         Expense[]
  taxReports       TaxReport[]
  revenues         Revenue[]
  userCategories   UserCategory[]
  quotes           Quote[]
  categoryBudgets  CategoryBudget[]
  timeEntries      TimeEntry[]
  employees        Employee[]
  documents        Document[]

  @@map("businesses")
}

model Client {
  id         String   @id @default(uuid())
  businessId String
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  postalCode String?
  country    String   @default("FR")
  siret      String?
  vatNumber  String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  quotes      Quote[]
  timeEntries TimeEntry[]

  @@map("clients")
}

model Invoice {
  id            String        @id @default(uuid())
  businessId    String
  clientId      String?
  number        String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  paidAt        DateTime?
  subtotal      Float         @default(0)
  vatRate       Float         @default(0)
  vatAmount     Float         @default(0)
  total         Float         @default(0)
  notes         String?
  paymentTerms  String?
  pdfUrl        String?
  stripeId      String?
  isRecurring        Boolean             @default(false)
  recurrenceInterval RecurrenceInterval?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  transactions Transaction[]

  @@unique([businessId, number])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  vatRate     Float   @default(0)
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Quote {
  id                 String      @id @default(cuid())
  businessId         String
  clientId           String?
  number             String
  status             QuoteStatus @default(DRAFT)
  issueDate          DateTime    @default(now())
  expiryDate         DateTime?
  subtotal           Float       @default(0)
  vatRate            Float       @default(0)
  vatAmount          Float       @default(0)
  total              Float       @default(0)
  notes              String?
  convertedInvoiceId String?     @unique
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  business Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items    QuoteItem[]

  @@map("quotes")
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  description String
  quantity    Float  @default(1)
  unitPrice   Float  @default(0)
  vatRate     Float  @default(0)
  total       Float  @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model Transaction {
  id          String          @id @default(uuid())
  businessId  String
  invoiceId   String?
  type        TransactionType
  amount      Float
  description String?
  date        DateTime        @default(now())
  category    String?
  reference   String?
  bankAccount String?
  isReconciled Boolean        @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Expense {
  id                 String              @id @default(uuid())
  businessId         String
  employeeId         String?
  category           ExpenseCategory     @default(OTHER)
  amount             Float
  vatAmount          Float               @default(0)
  description        String?
  date               DateTime            @default(now())
  receiptUrl         String?
  supplier           String?
  isDeductible       Boolean             @default(true)
  isRecurring        Boolean             @default(false)
  recurrenceInterval RecurrenceInterval?
  userCategoryId     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee     Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  userCategory UserCategory? @relation(fields: [userCategoryId], references: [id], onDelete: SetNull)

  @@map("expenses")
}

model Revenue {
  id                 String              @id @default(uuid())
  businessId         String
  category           RevenueCategory     @default(SERVICES)
  amount             Float
  vatAmount          Float               @default(0)
  description        String?
  date               DateTime            @default(now())
  clientName         String?
  isRecurring        Boolean             @default(false)
  recurrenceInterval RecurrenceInterval?
  userCategoryId     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userCategory UserCategory? @relation(fields: [userCategoryId], references: [id], onDelete: SetNull)

  @@map("revenues")
}

model UserCategory {
  id         String   @id @default(cuid())
  businessId String
  name       String
  slug       String
  color      String   @default("#378ADD")
  type       String   // "EXPENSE" or "REVENUE"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses Expense[]
  revenues Revenue[]

  @@unique([businessId, slug, type])
  @@map("user_categories")
}

model CategoryBudget {
  id         String   @id @default(cuid())
  businessId String
  category   String
  amount     Float
  period     String   @default("MONTHLY")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, category, period])
  @@map("category_budgets")
}

model TimeEntry {
  id          String   @id @default(cuid())
  businessId  String
  clientId    String?
  description String
  date        DateTime
  hours       Float
  hourlyRate  Float
  total       Float
  isBilled    Boolean  @default(false)
  invoiceId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("time_entries")
}

model TaxReport {
  id          String          @id @default(uuid())
  businessId  String
  type        TaxReportType
  status      TaxReportStatus @default(DRAFT)
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime?
  submittedAt DateTime?
  amount      Float           @default(0)
  details     Json?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("tax_reports")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  readAt    DateTime?
  link      String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model Employee {
  id                   String       @id @default(uuid())
  businessId           String
  firstName            String
  lastName             String
  email                String?
  phone                String?
  address              String?
  city                 String?
  postalCode           String?
  position             String?
  contractType         ContractType @default(CDI)
  grossSalary          Float
  startDate            DateTime
  endDate              DateTime?
  socialSecurityNumber String?
  iban                 String?
  isActive             Boolean      @default(true)
  notes                String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@map("employees")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(INACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Document {
  id         String   @id @default(uuid())
  businessId String
  name       String
  url        String
  category   String   @default("OTHER")
  mimeType   String?
  size       Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("documents")
}
